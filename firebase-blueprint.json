{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An ecommerce product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["shoes", "bags", "accessories"] },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isFeatured": { "type": "boolean" },
        "metadata": { "type": "object" }
      },
      "required": ["name", "price", "category", "images"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "integer" },
              "price": { "type": "number" },
              "name": { "type": "string" }
            }
          } 
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "shippingAddress": { "type": "string" }
      },
      "required": ["userId", "items", "totalAmount", "status"]
    },
    "User": {
      "title": "User",
      "description": "User profile with PII isolation",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Store available products"
    },
    "orders": {
      "schema": "Order",
      "description": "Store customer orders"
    },
    "users": {
        "schema": "User",
        "description": "Store user profile and roles"
    }
  }
}
